{
  "manifest_version": 3,
  "name": "Subscriptos",
  "version": "1.0.0",
  "description": "Protect your wallet from predatory subscriptions by generating virtual cards and translating ToS.",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/contentWorker.jsx"
      ]
    }
  ]
}