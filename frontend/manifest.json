{
  "manifest_version": 3,
  "name": "Subscription Shield",
  "version": "1.0.0",
  "description": "Protect your wallet from predatory subscriptions by generating virtual cards and translating ToS.",
  "action": {
    "default_popup": "index.html#/popup"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/contentWorker.js"]
    }
  ]
}
